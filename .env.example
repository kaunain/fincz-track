# ==========================================
# Fincz Track Environment Configuration
# ==========================================
# Copy this file to .env and update values accordingly
# DO NOT commit .env file to version control

# ==========================================
# SERVER CONFIGURATION
# ==========================================
SERVER_PORT=8080

# ==========================================
# DATABASE CONFIGURATION (PostgreSQL via Docker)
# ==========================================
# Format: postgresql://user:password@host:port/database
# For Docker: postgresql://user:password@postgres:5432/database
# For Local: postgresql://user:password@localhost:5432/database

DB_URL=postgresql://fincz_user:fincz_secure_password@postgres:5432/fincz_db
DB_USER=fincz_user
DB_PASS=fincz_secure_password
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=20000
DB_MAX_IDLE_TIME=600000

# ==========================================
# HIBERNATE/JPA CONFIGURATION
# ==========================================
# update = Create/alter tables as needed (development)
# validate = Only validate schema (production)
# create = Create new schema (test)
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ==========================================
# JWT (JSON Web Token) CONFIGURATION
# ==========================================
# Secret: Generate a strong Base64-encoded secret (at least 32 bytes)
# Command: python3 -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# Expiration: In milliseconds (3600000 = 1 hour, 86400000 = 24 hours)

JWT_SECRET=your_base64_encoded_secret_key_here_minimum_32_bytes_long
JWT_EXPIRATION=86400000

# ==========================================
# MICROSERVICES URLS (for API Gateway routing)
# ==========================================
# For Docker Compose: use service names
# For Local: use localhost with port numbers

AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
PORTFOLIO_SERVICE_URL=http://localhost:8083
MARKET_SERVICE_URL=http://localhost:8084
NOTIFICATION_SERVICE_URL=http://localhost:8085

# ==========================================
# MARKET DATA API CONFIGURATION
# ==========================================
# API Base URL for external market data service
# MARKET_API_KEY: Get from your broker/market data provider

MARKET_API_BASE_URL=https://api.example.com
MARKET_API_KEY=your_market_api_key_here

# ==========================================
# EMAIL/NOTIFICATION CONFIGURATION
# ==========================================
# For Gmail: 
#   - Enable "Less secure app access"
#   - Use app-specific password (not account password)
# For other SMTP providers: adjust host and port accordingly

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@fincz.com

# ==========================================
# NOTIFICATION SERVICE CONFIGURATION
# ==========================================
# Tax reminder: Days before tax deadline to send reminder
# Portfolio alert: Percentage change to trigger alert

TAX_REMINDER_DAYS=30
PORTFOLIO_ALERT_THRESHOLD=5.0

# ==========================================
# CACHE CONFIGURATION
# ==========================================
# Time to live for cache in milliseconds
# 300000 = 5 minutes, 600000 = 10 minutes

CACHE_TTL=300000

# ==========================================
# SPRING PROFILE CONFIGURATION
# ==========================================
# Profiles: dev, test, prod
# This affects which application-{profile}.yaml file is loaded

SPRING_PROFILES_ACTIVE=dev

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Log levels: DEBUG, INFO, WARN, ERROR

LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_FINCZ=DEBUG

# ==========================================
# APPLICATION FEATURES
# ==========================================
# Feature toggles and configuration flags

FEATURE_TAX_OPTIMIZATION=true
FEATURE_PORTFOLIO_ALERTS=true
FEATURE_MARKET_DATA=true
FEATURE_NOTIFICATIONS=true

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# CORS origins allowed to access the API
# Multiple origins can be comma-separated

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# DOCKER CONFIGURATION
# ==========================================
# PostgreSQL Docker image and setup

POSTGRES_DB=fincz_db
POSTGRES_USER=fincz_user
POSTGRES_PASSWORD=fincz_secure_password
POSTGRES_PORT=5432
POSTGRES_VERSION=15-alpine

# ==========================================
# DEVELOPMENT CONFIGURATION
# ==========================================
# Enable/disable debug features

DEBUG_MODE=true
SHOW_SQL=false
FORMAT_SQL=true
