@authBaseUrl = http://localhost:8081
@userBaseUrl = http://localhost:8082
@portfolioBaseUrl = http://localhost:8083
@marketBaseUrl = http://localhost:8084

### Auth Service Tests

### 1. Test Controller (Auth Service Status)
# Check if Auth Service is running properly.
GET {{authBaseUrl}}/test

###

### 2. User Signup (Auth Service)
# Register a new user.
POST {{authBaseUrl}}/auth/signup
Content-Type: application/json

{
    "name": "Test User",
    "email": "test@fincz.com",
    "password": "java@123"
}

###

### 3. User Login (Auth Service)
# @name login
# Authenticate and store the returned JWT in a global variable.
POST {{authBaseUrl}}/auth/login
Content-Type: application/json

{
    "email": "test@fincz.com",
    "password": "java@123"
}

###

@token = {{login.response.body.token}}

### 3.1 Create User Profile (User Service)
# Create user profile in user-service after signup
POST {{userBaseUrl}}/users/profile
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "name": "Test User",
    "email": "test@fincz.com",
    "password": "dummy_password"
}

###

### User Service Tests

### 4. Get Current User (User Service)
# Use the JWT from the login request to call the protected user endpoint.
GET {{userBaseUrl}}/users/me
Authorization: Bearer {{token}}

### 5. Update Current User (User Service)
# Update the authenticated user's profile.
PUT {{userBaseUrl}}/users/me
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "name": "Updated User",
    "phone": "+12345678901",
    "age": 30,
    "occupation": "Engineer",
    "financialGoals": "Save for retirement"
}

###

### 6. Get User by ID (User Service)
# Fetch a user by its numeric ID.
GET {{userBaseUrl}}/users/1
Authorization: Bearer {{token}}

###

### Portfolio Service Tests

### 7. Add Investment (Portfolio Service)
# Add a stock investment to portfolio
POST {{portfolioBaseUrl}}/portfolio/add
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "type": "stock",
    "name": "Tata Consultancy Services",
    "symbol": "TCS.NS",
    "units": 10,
    "buyPrice": 3200.50
}

###

### 8. Get Portfolio (Portfolio Service)
# Get user's complete portfolio
GET {{portfolioBaseUrl}}/portfolio
Authorization: Bearer {{token}}

###

### 9. Get Net Worth (Portfolio Service)
# Get user's net worth calculation
GET {{portfolioBaseUrl}}/portfolio/networth
Authorization: Bearer {{token}}

###

### 10. Add Mutual Fund Investment (Portfolio Service)
# Add a mutual fund investment
POST {{portfolioBaseUrl}}/portfolio/add
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "type": "mf",
    "name": "HDFC Flexi Cap Fund",
    "symbol": "HDFCFCF",
    "units": 100,
    "buyPrice": 150.75
}

###

### 11. Get Stock Portfolio (Portfolio Service)
# Get only stock investments
GET {{portfolioBaseUrl}}/portfolio/type/stock
Authorization: Bearer {{token}}

###

### Market Data Service Tests

### 12. Get Stock Price (Market Data Service)
# Get current price for TCS stock
GET {{marketBaseUrl}}/market/price/TCS.NS

###

### 13. Get Mutual Fund Price (Market Data Service)
# Get current price for HDFC Flexi Cap Fund
GET {{marketBaseUrl}}/market/price/HDFCFCF

###

### Notification Service Tests

@notificationBaseUrl = http://localhost:8085

### 14. Notification Service Health Check
# Check if Notification Service is running
GET {{notificationBaseUrl}}/notifications/test

###

### 15. Send Notification (Notification Service)
# Send a test notification
POST {{notificationBaseUrl}}/notifications/send
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "toEmail": "test@fincz.com",
  "subject": "Portfolio Update",
  "message": "Your portfolio has been updated successfully!"
}

###

### 16. Get User Notifications (Notification Service)
# Get notification history for authenticated user
GET {{notificationBaseUrl}}/notifications
Authorization: Bearer {{token}}

###

### 17. Trigger Tax Reminder (Notification Service)
# Manually trigger tax reminder check
POST {{notificationBaseUrl}}/notifications/tax-reminder
Authorization: Bearer {{token}}

###

### 18. Trigger Portfolio Alert (Notification Service)
# Manually trigger portfolio alert check
POST {{notificationBaseUrl}}/notifications/portfolio-alert
Authorization: Bearer {{token}}

###

### Additional Portfolio Service Tests

### 19. Get Mutual Fund Portfolio (Portfolio Service)
# Get only mutual fund investments
GET {{portfolioBaseUrl}}/portfolio/type/mf
Authorization: Bearer {{token}}

###

### Additional Market Data Tests

### 20. Get Stock Price for Different Symbol (Market Data Service)
# Get current price for Infosys stock
GET {{marketBaseUrl}}/market/price/INFY.NS

###

### 21. Get Mutual Fund Price for Different Fund (Market Data Service)
# Get current price for SBI Bluechip Fund
GET {{marketBaseUrl}}/market/price/SBIBCF

###